//Motor PINs
#define ENA 16
#define IN1 5
#define IN2 4
#define IN3 0
#define IN4 2
#define ENB 14
#define switch 13
#define S1 12
#define S2 15
bool forward = 0;
bool backward = 0;
bool left = 0;
bool right = 0;
int Speed;
char auth[] = "Enter your Blynk auth token";
char ssid[] = "Enter your WIFI name":
char pass[] = "Enter your WIFI passowrd";
void setup() {
Serial.begin(9600);
pinMode(ENA, OUTPUT);
pinMode(IN1, OUTPUT);
pinMode(IN2, OUTPUT);
pinMode(IN3, OUTPUT);
pinMode(IN4, OUTPUT);
pinMode(ENB, OUTPUT);
pinMode(S1, INPUT);
pinMode(S2, INPUT);
